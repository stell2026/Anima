# OpenRouter API key (required)
# Get one at https://openrouter.ai
OPENROUTER_API_KEY=

# Optional: separate key for the input LLM (second account avoids rate limits)
# Falls back to OPENROUTER_API_KEY if not set
OPENROUTER_API_KEY_INPUT=

# Output LLM model
ANIMA_LLM_MODEL=anthropic/claude-haiku-4.5

# Input LLM model (translates user text into JSON stimulus)
ANIMA_INPUT_LLM_MODEL=openai/gpt-oss-120b:free

# API endpoint (default is OpenRouter; change for Ollama or other providers)
ANIMA_LLM_URL=https://openrouter.ai/api/v1/chat/completions

# Directory for state JSON files and GUI data (relative to project root)
ANIMA_STATE_DIR=data

# Telegram bot (only needed for run_anima_telegram.jl)
# ANIMA_TELEGRAM_TOKEN=
# ANIMA_TELEGRAM_CHAT_ID=
